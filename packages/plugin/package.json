{
  "name": "@echoscript/yarn-plugin",
  "description": "Run echoscript via yarn plugin.",
  "version": "0.3.0",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bundle": "rollup --silent --config ./rollup.config.js --bundleConfigAsCjs",
    "build": "yarn build:clear && yarn build:types",
    "build:clear": "rm -rf ./dist && mkdir -p ./dist",
    "build:types": "tsc -b && tsc-alias"
  },
  "devDependencies": {
    "@echoscript/core": "workspace:^",
    "@echoscript/types": "workspace:^",
    "@rollup/plugin-commonjs": "^26.0.0",
    "@rollup/plugin-node-resolve": "^15.3.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.1.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@yarnpkg/core": "^4.1.3",
    "rollup": "^4.30.0",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.0",
    "typescript": "^5.9.0"
  },
  "gitHead": "666f5bb6b39213db9fb8c6dd2f3f28413e7cce78"
}
