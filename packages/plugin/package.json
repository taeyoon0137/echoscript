{
  "name": "@echoscript/yarn-plugin",
  "description": "Run echoscript via yarn plugin.",
  "version": "0.4.0",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "bundle": "rollup --silent --config ./rollup.config.js --bundleConfigAsCjs",
    "build": "yarn build:clear && yarn build:types",
    "build:clear": "rm -rf ./dist && mkdir -p ./dist",
    "build:types": "tsc -p tsconfig.json && tsc-alias"
  },
  "devDependencies": {
    "@echoscript/core": "workspace:^",
    "@echoscript/types": "workspace:^",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@total-typescript/ts-reset": "^0.6.1",
    "@yarnpkg/core": "^4.7.0",
    "rollup": "^4.60.2",
    "tsc-alias": "^1.8.16",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3"
  },
  "gitHead": "666f5bb6b39213db9fb8c6dd2f3f28413e7cce78"
}
