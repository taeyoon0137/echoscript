{
  "$ref": "#/definitions/echoscriptrc",
  "definitions": {
    "echoscriptrc": {
      "$schema": "https://json-schema.org/draft/2020-12/schema",
      "allOf": [
        {
          "type": "object",
          "properties": {
            "projectNameMaxLength": {
              "default": 30,
              "type": "number",
              "minimum": 1
            },
            "rootProject": {
              "default": "🔈",
              "type": "string",
              "minLength": 1
            },
            "project": {
              "type": "string",
              "minLength": 1
            },
            "start": {
              "default": "Starting script...🔥",
              "type": "string",
              "minLength": 1
            },
            "error": {
              "default": "Error occurred ❌",
              "type": "string",
              "minLength": 1
            },
            "end": {
              "default": "Script done ✅",
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "type": "object",
          "properties": {
            "$schema": {
              "type": "string"
            }
          },
          "required": [
            "$schema"
          ]
        }
      ]
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}
