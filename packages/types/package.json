{
  "name": "@echoscript/types",
  "description": "Type definition for Echoscript.",
  "version": "0.3.0",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "ready": "yarn build && yarn schema",
    "build": "yarn build:clear && yarn build:types",
    "build:clear": "rm -rf ./dist && mkdir -p ./dist",
    "build:types": "tsc -p tsconfig.json && tsc-alias",
    "schema": "tsx scripts/schema.ts"
  },
  "devDependencies": {
    "@total-typescript/ts-reset": "^0.6.1",
    "@types/node": "^22.0.0",
    "prettier": "^3.8.1",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.19.0",
    "typescript": "^5.9.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.25.1"
  },
  "peerDependencies": {
    "zod": ">=4.0.0"
  },
  "gitHead": "666f5bb6b39213db9fb8c6dd2f3f28413e7cce78"
}
